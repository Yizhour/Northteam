# Flask
FLASK_ENV=production
SECRET_KEY=change-me

# Scheduler
# Set to 0 when running multiple Gunicorn workers and use a single separate scheduler process.
ENABLE_SCHEDULER=1

# SMTP defaults preserve the original desktop application behavior.
SMTP_HOST=smtp.163.com
SMTP_PORT=465
SMTP_ALT_SSL_PORT=994
SMTP_STARTTLS_PORT=587
SMTP_TIMEOUT=8
